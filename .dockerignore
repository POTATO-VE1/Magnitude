*.pyc

# Test files
*_test.go

# OS junk
.DS_Store
Thumbs.db

# IDE / tool folders
.vscode/
.idea/

# Git
.git/
.gitignore

# Documentation
*.md
LICENSE

# Logs and temp files
*.log
*.tmp
*.swp
*.bak
