# ── Runtime data (generated by the server) ──
data/

# ── SSL certificates (security-sensitive, never commit) ──
certs/
*.pem
*.key
*.crt

# ── Environment secrets ──
*.env
*.env.*
!.env.example

# ── Python virtual environment ──
python-client/venv/
python-client/.venv/

# ── Downloaded image datasets (too large for git) ──
python-client/images/
test_images/

# ── Python bytecode & build artifacts ──
__pycache__/
*.pyc
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# ── Python constraints (generated, machine-specific) ──
python-client/constraints-cpu.txt

# ── OS junk ──
.DS_Store
Thumbs.db

# ── IDE / tool folders ──
.vscode/
.idea/

# ── Logs, PID files, and temp files ──
*.log
*.pid
*.tmp
*.swp
*.bak
nohup.out

# ── Debug / scratch output ──
search_result.json

# ── AI Generated Files ──
TIER3_IMPLEMENTATION_PLAN.md
agent.md
context.md

# ── Compiled binary ──
server

# ── Scratch / internal docs (not for repo) ──
scratch/
docs/
