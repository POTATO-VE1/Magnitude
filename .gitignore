# ── Runtime data (generated by the server) ──
data/

# ── SSL certificates (security-sensitive, never commit) ──
certs/
*.pem
*.key
*.crt

# ── Environment secrets ──
*.env
*.env.*
!.env.example

# ── Python virtual environment ──
python-client/venv/

# ── Downloaded image datasets (too large for git) ──
python-client/images/

# ── Python bytecode ──
__pycache__/
*.pyc

# ── OS junk ──
.DS_Store
Thumbs.db

# ── IDE / tool folders ──
.vscode/
.idea/

# ── Logs and temp files ──
*.log
*.tmp
*.swp
*.bak

